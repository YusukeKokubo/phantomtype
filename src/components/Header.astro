---
import type { City } from "../../@types/Photo"

interface Props {
  city: string
  cities: City[]
}

const { city, cities } = Astro.props
---

<nav
  class="flex px-5 w-full justify-between bg-surface"
  aria-label="メインナビゲーション"
>
  <div class="mt-2">
    <a href="/" aria-label="トップページへ戻る">
      <img
        class="inline align-baseline w-8 mr-1"
        src="/logomark-white.svg"
        alt="PHANTOM TYPE ロゴ"
      />
      <span class="hidden md:inline leading-loose text-2xl">PHANTOM TYPE</span>
    </a>
  </div>
  <div class="flex flex-col md:flex-row md:gap-4 items-center justify-center">
    {
      cities.map((c) => (
        <a
          href={`/${c.city}`}
          aria-current={c.city === city ? "page" : undefined}
        >
          <span
            class={`text-lg uppercase ${c.city === city ? "text-foreground" : "text-text-secondary"} hover:text-foreground focus-visible:outline-2 focus-visible:outline-offset-2`}
          >
            {c.city}
          </span>
        </a>
      ))
    }
  </div>
</nav>
