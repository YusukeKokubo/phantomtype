---
import type { TimelineEntry } from "../../@types/About"

interface Props {
  entries: TimelineEntry[]
  modalIds?: Record<string, string>
}

const { entries, modalIds = {} } = Astro.props

const today = new Date()
const sorted = [...entries].sort((a, b) => a.date.localeCompare(b.date))

function formatRange(entry: TimelineEntry): string {
  const s = new Date(entry.date)
  const sy = s.getFullYear()
  const sm = s.getMonth() + 1
  if (!entry.endDate || entry.endDate === "Now") {
    return `${sy}.${String(sm).padStart(2, "0")} – 現在`
  }
  const e = new Date(entry.endDate)
  return `${sy}.${String(sm).padStart(2, "0")} – ${e.getFullYear()}.${String(e.getMonth() + 1).padStart(2, "0")}`
}

type YearMarker = { year: number; leftPct: number; transform: string }
type EntrySeg = {
  type: "entry"
  leftPct: number
  widthPct: number
  entry: TimelineEntry
  yearRange: string
  modalId?: string
  isCurrent: boolean
  bgColor: string
  dotColor: string
}
type GapSeg = { type: "gap"; leftPct: number; widthPct: number }
type RowData = {
  yearMarkers: YearMarker[]
  gapSegs: GapSeg[]
  entrySegs: EntrySeg[]
}

function buildRow(rowEntries: TimelineEntry[]): RowData {
  if (rowEntries.length === 0) return { yearMarkers: [], gapSegs: [], entrySegs: [] }

  const rowStartYear = new Date(rowEntries[0]!.date).getFullYear()
  const lastEntry = rowEntries[rowEntries.length - 1]!
  const lastEndDate =
    !lastEntry.endDate || lastEntry.endDate === "Now" ? today : new Date(lastEntry.endDate)
  const rowEndYear = lastEndDate.getFullYear() + 1
  const totalM = (rowEndYear - rowStartYear) * 12

  function mo(date: Date): number {
    return (date.getFullYear() - rowStartYear) * 12 + date.getMonth()
  }
  function pct(m: number): number {
    return (m / totalM) * 100
  }

  const gapSegs: GapSeg[] = []
  const entrySegs: EntrySeg[] = []
  let cursorM = 0

  for (const entry of rowEntries) {
    const startM = mo(new Date(entry.date))
    const isCurrent = !entry.endDate || entry.endDate === "Now"
    const endDate = isCurrent ? today : new Date(entry.endDate!)
    const endM = mo(endDate) + 1
    const effectiveStartM = Math.max(startM, cursorM)

    if (effectiveStartM > cursorM) {
      gapSegs.push({ type: "gap", leftPct: pct(cursorM), widthPct: pct(effectiveStartM - cursorM) })
    }

    const color = entry.color ?? "#6B7280"
    entrySegs.push({
      type: "entry",
      leftPct: pct(effectiveStartM),
      widthPct: pct(endM - effectiveStartM),
      entry,
      yearRange: formatRange(entry),
      modalId: modalIds[`${entry.date}-${entry.title}`],
      isCurrent,
      bgColor: color,
      dotColor: color,
    })

    cursorM = endM
  }

  const keyYears: number[] = [rowStartYear]
  for (let y = Math.ceil(rowStartYear / 5) * 5; y < rowEndYear; y += 5) {
    if (y !== rowStartYear) keyYears.push(y)
  }
  const yearMarkers: YearMarker[] = keyYears.map((year, i, arr) => ({
    year,
    leftPct: pct((year - rowStartYear) * 12),
    transform: i === 0 ? "translateX(0)" : i === arr.length - 1 ? "translateX(-100%)" : "translateX(-50%)",
  }))

  return { yearMarkers, gapSegs, entrySegs }
}

const half = Math.ceil(sorted.length / 2)
const rows: RowData[] =
  sorted.length > 2
    ? [buildRow(sorted.slice(0, half)), buildRow(sorted.slice(half))]
    : [buildRow(sorted)]
---

{
  entries.length === 0 ? (
    <p class="text-text-secondary">コンテンツを追加してください</p>
  ) : (
    <div class="py-8 px-4">
      <div class="mx-auto max-w-5xl space-y-6">
        {rows.map((row) => (
          <div class="space-y-3">
            <div class="overflow-x-auto">
              <div style="min-width: 480px">
                {/* Year ruler */}
                <div class="relative h-7 mb-1 select-none">
                  {row.yearMarkers.map(({ year, leftPct, transform }) => (
                    <div
                      class="absolute flex flex-col items-center"
                      style={`left: ${leftPct}%; transform: ${transform}`}
                    >
                      <span class="text-xs text-text-secondary whitespace-nowrap">{year}</span>
                      <div class="w-px h-2 bg-border mt-0.5" />
                    </div>
                  ))}
                </div>

                {/* Strip */}
                <div class="relative h-28 sm:h-32 md:h-36 rounded-xl overflow-hidden border border-border bg-surface-variant">
                  {row.gapSegs.map(({ leftPct, widthPct }) => (
                    <div
                      class="absolute inset-y-0"
                      style={`left: ${leftPct}%; width: ${widthPct}%`}
                    />
                  ))}
                  {row.entrySegs.map(({ entry, modalId, isCurrent, leftPct, widthPct, bgColor }) => (
                    <div
                      class="absolute inset-y-0 border-l border-white/20 first:border-l-0"
                      style={`left: ${leftPct}%; width: ${widthPct}%; background-color: ${bgColor}`}
                    >
                      {modalId ? (
                        <button
                          type="button"
                          data-modal-title={entry.title}
                          data-modal-id={modalId}
                          class="relative w-full h-full flex flex-col items-center justify-center gap-1.5 px-2 py-2 overflow-hidden hover:brightness-110 transition-brightness cursor-pointer focus-visible:outline-2 focus-visible:outline-offset-2"
                        >
                          <div class="absolute inset-x-0 bottom-0 h-10 bg-gradient-to-t from-black/30 to-transparent pointer-events-none" />
                          {entry.image ? (
                            <div class="bg-white/90 rounded-md px-2 py-1 flex items-center justify-center shrink-0" style="height: 2.25rem; max-width: 80%">
                              <img src={entry.image} alt={entry.title} class="max-h-full max-w-full object-contain" loading="lazy" />
                            </div>
                          ) : (
                            <span class="text-sm sm:text-base font-bold text-white drop-shadow text-center leading-tight line-clamp-2 z-10">{entry.title}</span>
                          )}
                          {entry.image && <span class="text-xs font-semibold text-white/90 drop-shadow text-center leading-tight line-clamp-1 z-10 hidden sm:block">{entry.title}</span>}
                          {isCurrent && <span class="absolute top-1.5 right-2 text-xs font-medium text-white/80 z-10">NOW</span>}
                        </button>
                      ) : (
                        <div class="relative w-full h-full flex flex-col items-center justify-center gap-1.5 px-2 py-2 overflow-hidden">
                          <div class="absolute inset-x-0 bottom-0 h-10 bg-gradient-to-t from-black/30 to-transparent pointer-events-none" />
                          {entry.image ? (
                            <div class="bg-white/90 rounded-md px-2 py-1 flex items-center justify-center shrink-0" style="height: 2.25rem; max-width: 80%">
                              <img src={entry.image} alt={entry.title} class="max-h-full max-w-full object-contain" loading="lazy" />
                            </div>
                          ) : (
                            <span class="text-sm sm:text-base font-bold text-white drop-shadow text-center leading-tight line-clamp-2 z-10">{entry.title}</span>
                          )}
                          {entry.image && <span class="text-xs font-semibold text-white/90 drop-shadow text-center leading-tight line-clamp-1 z-10 hidden sm:block">{entry.title}</span>}
                          {isCurrent && <span class="absolute top-1.5 right-2 text-xs font-medium text-white/80 z-10">NOW</span>}
                        </div>
                      )}
                    </div>
                  ))}
                </div>
              </div>
            </div>

            {/* Row legend */}
            <div class="flex flex-wrap gap-2 sm:gap-3">
              {row.entrySegs.map(({ entry, yearRange, modalId, dotColor }) => (
                <div class="bg-surface border border-border rounded-lg px-3 py-2 hover:shadow-sm transition-shadow">
                  {modalId ? (
                    <button
                      type="button"
                      data-modal-title={entry.title}
                      data-modal-id={modalId}
                      class="flex items-center gap-2 text-sm cursor-pointer hover:opacity-80 transition-opacity focus-visible:outline-2 focus-visible:outline-offset-2"
                    >
                      <div class="w-2.5 h-2.5 rounded-full shrink-0" style={`background-color: ${dotColor}`} />
                      <span class="font-medium text-foreground">{entry.title}</span>
                      <span class="text-xs text-text-secondary">{yearRange}</span>
                    </button>
                  ) : (
                    <div class="flex items-center gap-2 text-sm">
                      <div class="w-2.5 h-2.5 rounded-full shrink-0" style={`background-color: ${dotColor}`} />
                      <span class="font-medium text-foreground">{entry.title}</span>
                      <span class="text-xs text-text-secondary">{yearRange}</span>
                    </div>
                  )}
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  )
}
