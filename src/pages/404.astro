---
import BaseLayout from "../layouts/BaseLayout.astro"
---

<BaseLayout title="404 | PHANTOM TYPE" description="ページが見つかりません">
  <main id="main" class="flex flex-col items-center justify-center h-screen gap-4">
    <h1 class="text-4xl font-light">404</h1>
    <p class="text-text-secondary">ページが見つかりません</p>
    <a
      href="/"
      class="text-text-secondary hover:text-foreground focus-visible:outline-2 focus-visible:outline-offset-2"
    >
      ← トップページへ戻る
    </a>
  </main>
</BaseLayout>
