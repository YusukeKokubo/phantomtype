---
export const prerender = true

import { getImage, Image } from "astro:assets"
import type { City, Photo } from "../../../../@types/Photo"
import picsData from "../../../../public/pics.json"
import Header from "../../../components/Header.astro"
import BaseLayout from "../../../layouts/BaseLayout.astro"
import { calcSize } from "../../../lib/calc-size"
import { DETAIL_WIDTHS, OGP_WIDTH } from "../../../lib/image-config"
import { loadImage } from "../../../lib/images"

export function getStaticPaths() {
  const cities = picsData as City[]
  return cities
    .filter((c) => c.city !== "yusuke")
    .flatMap((cityData) => {
      const allPics = cityData.locations
        .flatMap((loc) => loc.pics.filter((p) => p.exif))
        .sort((a, b) =>
          a.exif!.DateTimeOriginal < b.exif!.DateTimeOriginal ? -1 : 1,
        )
      return allPics.map((pic, index) => ({
        params: { city: cityData.city, filename: pic.filename },
        props: {
          photo: pic,
          cities,
          prevPhoto: index > 0 ? allPics[index - 1] : null,
          nextPhoto: index < allPics.length - 1 ? allPics[index + 1] : null,
        },
      }))
    })
}

interface Props {
  photo: Photo
  cities: City[]
  prevPhoto: Photo | null
  nextPhoto: Photo | null
}

const { photo, cities, prevPhoto, nextPhoto } = Astro.props
const { city } = Astro.params

const name = photo.filename.substring(0, photo.filename.indexOf("."))
const exif = photo.exif
const { width, height } = calcSize(exif, 1920, 1080)

const publicHost = import.meta.env.PUBLIC_HOST || ""
const image = await loadImage(photo.url)
const og = await getImage({ src: image, width: OGP_WIDTH, format: "webp" })
const ogImage = `${publicHost}${og.src}`
const ogUrl = `${publicHost}/${city}/photo/${encodeURIComponent(photo.filename)}`
---

<BaseLayout
  title={`${name} | ${city.toUpperCase()} | PHANTOM TYPE`}
  description={`${city} ${name}の写真`}
  ogImage={ogImage}
  ogUrl={ogUrl}
  ogImageWidth={String(width)}
  ogImageHeight={String(height)}
>
  <a href="#main-content" class="skip-link">メインコンテンツへスキップ</a>
  <Header city={city} cities={cities} />
  <main id="main-content" class="px-4 py-3 flex flex-col gap-3">
    <nav aria-label="ナビゲーション" class="flex items-center justify-between">
      <a
        href={`/${city}`}
        class="text-text-secondary hover:text-foreground text-lg uppercase focus-visible:outline-2 focus-visible:outline-offset-2"
      >
        ← {city}
      </a>
      <div class="flex gap-4">
        {
          prevPhoto ? (
            <a
              id="nav-prev"
              href={`/${city}/photo/${encodeURIComponent(prevPhoto.filename)}`}
              class="text-text-secondary hover:text-foreground text-lg focus-visible:outline-2 focus-visible:outline-offset-2"
              aria-label="前の写真"
            >
              ←
            </a>
          ) : (
            <span class="text-text-secondary/30 text-lg" aria-hidden="true">←</span>
          )
        }
        {
          nextPhoto ? (
            <a
              id="nav-next"
              href={`/${city}/photo/${encodeURIComponent(nextPhoto.filename)}`}
              class="text-text-secondary hover:text-foreground text-lg focus-visible:outline-2 focus-visible:outline-offset-2"
              aria-label="次の写真"
            >
              →
            </a>
          ) : (
            <span class="text-text-secondary/30 text-lg" aria-hidden="true">→</span>
          )
        }
      </div>
    </nav>

    <article>
      <div class="relative overflow-hidden mx-auto w-max max-w-full">
        {
          photo.lqip && (
            <div
              class="absolute inset-0 bg-cover bg-center scale-110 blur-lg"
              style={`background-image: url(${photo.lqip})`}
              aria-hidden="true"
            />
          )
        }
        <Image
          src={image}
          widths={[...DETAIL_WIDTHS]}
          sizes="(max-width: 1920px) 100vw, 1920px"
          width={width}
          height={height}
          alt={`${city} ${name}の写真`}
          class="relative w-auto h-auto max-w-full max-h-[calc(100svh-11rem)] mx-auto block"
          transition:name={`photo-${photo.filename}`}
          {...(photo.lqip ? { "data-lqip": "" } : {})}
          onload={photo.lqip ? "this.dataset.lqipLoaded = ''" : undefined}
        />
      </div>

      {
        exif && (
          <section aria-labelledby="exif-heading" class="pt-4">
            <h2 id="exif-heading" class="sr-only">
              撮影情報
            </h2>
            <table class="w-full">
              <caption class="sr-only">EXIF メタデータ</caption>
              <tbody>
                <tr class="border-b border-border">
                  <th scope="row" class="text-text-secondary text-right pr-4">
                    撮影日時
                  </th>
                  <td class="text-foreground">{exif.DateTimeOriginal}</td>
                </tr>
                <tr class="border-b border-border">
                  <th scope="row" class="text-text-secondary text-right pr-4">
                    カメラ
                  </th>
                  <td class="text-foreground">
                    {exif.Make} {exif.Model}
                  </td>
                </tr>
                <tr class="border-b border-border">
                  <th scope="row" class="text-text-secondary text-right pr-4">
                    レンズ
                  </th>
                  <td class="text-foreground">{exif.LensModel.replace(/\0/g, "")}</td>
                </tr>
                <tr class="border-b border-border">
                  <th scope="row" class="text-text-secondary text-right pr-4">
                    絞り
                  </th>
                  <td class="text-foreground">{exif.FNumber}</td>
                </tr>
                <tr class="border-b border-border">
                  <th scope="row" class="text-text-secondary text-right pr-4">
                    焦点距離
                  </th>
                  <td class="text-foreground">
                    {exif.FocalLength} ({exif.FocalLengthIn35mmFormat} mm)
                  </td>
                </tr>
                <tr class="border-b border-border">
                  <th scope="row" class="text-text-secondary text-right pr-4">
                    シャッター速度
                  </th>
                  <td class="text-foreground">{exif.ExposureTime}S</td>
                </tr>
                <tr class="border-b border-border">
                  <th scope="row" class="text-text-secondary text-right pr-4">
                    ISO
                  </th>
                  <td class="text-foreground">ISO {exif.ISO}</td>
                </tr>
              </tbody>
            </table>
          </section>
        )
      }
    </article>
  </main>
<script>
  function setupKeyNav() {
    const handler = (e: KeyboardEvent) => {
      if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement) return
      if (e.key === "ArrowLeft") {
        (document.getElementById("nav-prev") as HTMLAnchorElement | null)?.click()
      } else if (e.key === "ArrowRight") {
        (document.getElementById("nav-next") as HTMLAnchorElement | null)?.click()
      }
    }
    document.addEventListener("keydown", handler)
    document.addEventListener("astro:before-swap", () => {
      document.removeEventListener("keydown", handler)
    }, { once: true })
  }
  setupKeyNav()
  document.addEventListener("astro:page-load", setupKeyNav)

  function markCachedLqipImages() {
    document.querySelectorAll<HTMLImageElement>("img[data-lqip]:not([data-lqip-loaded])").forEach((img) => {
      if (img.complete) img.dataset.lqipLoaded = ""
    })
  }
  markCachedLqipImages()
  document.addEventListener("astro:page-load", markCachedLqipImages)
</script>
</BaseLayout>
