---
export const prerender = true

import { getCollection } from "astro:content"
import type { TimelineEntry } from "../../@types/About"
import BaseLayout from "../layouts/BaseLayout.astro"
import { blogEntries } from "../yusuke/blog/index"
import { personalEntries } from "../yusuke/personal-data"
import CareerStrip from "../yusuke/CareerStrip.astro"
import {
  formatYearMonth,
  getRelativeTime,
  markdownToHtml,
} from "../yusuke/utils"

const today = new Date()

const careerCollectionEntries = await getCollection("career")
const sorted = careerCollectionEntries.sort((a, b) =>
  b.data.date.localeCompare(a.data.date),
)

const careerEntries: TimelineEntry[] = sorted.map((entry) => ({
  date: entry.data.date,
  endDate: entry.data.endDate,
  title: entry.data.title,
  image: entry.data.image,
  color: entry.data.color,
}))

// Pre-render career detail markdown for modals
const careerDetails = sorted
  .filter((entry) => entry.body)
  .map((entry) => ({
    modalId: `career-detail-${entry.data.date}`,
    title: entry.data.title,
    date: entry.data.date,
    html: markdownToHtml(entry.body ?? ""),
  }))

const modalIds: Record<string, string> = Object.fromEntries(
  careerDetails.map((d) => [`${d.date}-${d.title}`, d.modalId]),
)

// Writing: blog (external) + notes (internal) unified timeline
type WritingItem =
  | { kind: "note"; date: string; title: string; slug: string }
  | {
      kind: "blog"
      date: string
      title: string
      url: string
      platformName: string
      iconImage: string
    }

const notesCollectionEntries = await getCollection("notes")
const noteItems: WritingItem[] = notesCollectionEntries.map((entry) => ({
  kind: "note",
  date: entry.data.date,
  title: entry.data.title,
  slug: entry.id,
}))

const blogItems: WritingItem[] = blogEntries.map((entry) => ({
  kind: "blog",
  date: entry.date,
  title: entry.title,
  url: entry.url,
  platformName: entry.platformName,
  iconImage: entry.iconImage,
}))

const writingByYear = new Map<string, WritingItem[]>()
for (const item of [...noteItems, ...blogItems]) {
  const year = item.date.substring(0, 4)
  if (!writingByYear.has(year)) writingByYear.set(year, [])
  writingByYear.get(year)!.push(item)
}
const writingYearGroups = [...writingByYear.entries()]
  .map(([year, items]) => ({
    year,
    isRecent: parseInt(year) >= today.getFullYear() - 3,
    items: items.sort((a, b) => b.date.localeCompare(a.date)),
  }))
  .sort((a, b) => b.year.localeCompare(a.year))
---

<BaseLayout
  title="Yusuke Kokubo | PHANTOM TYPE"
  description="Yusuke Kokubo - Software Engineer in Nagoya, Japan"
>
  <main id="main-content">
    <!-- Profile -->
    <div class="max-w-3xl mx-auto px-8 pt-16 pb-8">
      <p>
        <img
          src="/yusuke/jikokuten.png"
          alt="Yusuke Kokubo"
          class="w-12 h-12 border rounded"
        />
        I'm Yusuke Kokubo, a software engineer living in Nagoya, Japan🇯🇵.
      </p>
      <p>My Skills are Web Development and a bit of Web UI Design.</p>
      <p>Love cats 🐈 and photography 📷.</p>
    </div>

    <!-- Career -->
    <section class="py-8 border-t border-border">
      <h2 class="max-w-3xl mx-auto px-8 text-xl font-semibold text-foreground mb-2">Career</h2>
      <CareerStrip entries={careerEntries} modalIds={modalIds} />
    </section>

    <!-- Personal -->
    <section class="py-8 border-t border-border">
      <h2 class="max-w-3xl mx-auto px-8 text-xl font-semibold text-foreground mb-6">Personal</h2>
      <div class="max-w-3xl mx-auto px-4">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {personalEntries.map((entry) => (
            entry.url ? (
              <a
                href={entry.url}
                target="_blank"
                rel="noopener noreferrer"
                class="block focus-visible:outline-2 focus-visible:outline-offset-2"
              >
                <div class="flex flex-col h-full bg-surface border border-border rounded-lg overflow-hidden hover:shadow-lg transition-shadow">
                  {entry.image && (
                    <div class="w-full aspect-video overflow-hidden bg-surface-variant">
                      <img src={entry.image} alt={entry.title} class="w-full h-full object-cover" loading="lazy" />
                    </div>
                  )}
                  <div class="p-4 flex flex-col gap-2 flex-1">
                    <div class="font-medium text-lg">{entry.title}</div>
                    {entry.description && (
                      <div class="text-sm text-text-secondary line-clamp-2">{entry.description}</div>
                    )}
                  </div>
                </div>
              </a>
            ) : (
              <div>
                <div class="flex flex-col h-full bg-surface border border-border rounded-lg overflow-hidden">
                  {entry.image && (
                    <div class="w-full aspect-video overflow-hidden bg-surface-variant">
                      <img src={entry.image} alt={entry.title} class="w-full h-full object-cover" loading="lazy" />
                    </div>
                  )}
                  <div class="p-4 flex flex-col gap-2 flex-1">
                    <div class="font-medium text-lg">{entry.title}</div>
                    {entry.description && (
                      <div class="text-sm text-text-secondary line-clamp-2">{entry.description}</div>
                    )}
                  </div>
                </div>
              </div>
            )
          ))}
        </div>
      </div>
    </section>

    <!-- Blog / Writing -->
    <section class="py-8 border-t border-border">
      <h2 class="max-w-3xl mx-auto px-8 text-xl font-semibold text-foreground mb-6">Writing</h2>
      <div class="max-w-3xl mx-auto py-2 px-4 flex flex-col gap-8">
        {writingYearGroups.map(({ year, items, isRecent }) => (
          <details open={isRecent} class="group">
            <summary class="flex items-center gap-2 cursor-pointer list-none mb-6 [&::-webkit-details-marker]:hidden">
              <h3 class="text-2xl font-bold text-foreground">{year}</h3>
              <svg class="w-5 h-5 text-text-secondary transition-transform duration-200 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="relative">
              <div class="absolute left-4 top-0 bottom-0 w-0.5 border-l border-dashed border-border" />
              <div class="space-y-8">
                {items.map((item) => (
                  <div class="relative flex items-start gap-4">
                    <div class="relative z-10 shrink-0">
                      <div class="w-8 h-8 rounded-full bg-background flex items-center justify-center shadow-md border-2 border-background p-1.5">
                        {item.kind === "blog" ? (
                          <img src={item.iconImage} alt={item.platformName} class="w-full h-full" />
                        ) : (
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-full h-full text-text-secondary">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931z" />
                          </svg>
                        )}
                      </div>
                    </div>
                    <div class="flex-1 min-w-0 pt-1">
                      <div class="text-sm text-text-secondary mb-3">
                        {item.kind === "blog" ? (
                          <span><strong class="font-semibold">{item.platformName}</strong>{" "}に投稿しました {getRelativeTime(item.date)}</span>
                        ) : (
                          <span>メモ {getRelativeTime(item.date)}</span>
                        )}
                      </div>
                      <div class="bg-surface border border-border rounded shadow-md hover:shadow-lg transition-shadow max-w-md">
                        {item.kind === "blog" ? (
                          <a href={item.url} target="_blank" rel="noopener noreferrer" class="block p-4 hover:opacity-80 transition-opacity focus-visible:outline-2 focus-visible:outline-offset-2">
                            <div class="text-sm font-medium text-text-muted mb-1">{formatYearMonth(item.date)}</div>
                            <div class="font-semibold text-foreground">{item.title}</div>
                          </a>
                        ) : (
                          <a href={`/yusuke/notes/${item.slug}`} class="block p-4 hover:opacity-80 transition-opacity focus-visible:outline-2 focus-visible:outline-offset-2">
                            <div class="text-sm font-medium text-text-muted mb-1">{formatYearMonth(item.date)}</div>
                            <div class="font-semibold text-foreground">{item.title}</div>
                          </a>
                        )}
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </details>
        ))}
      </div>
    </section>
  </main>

  <!-- Pre-rendered career detail content for modals -->
  {careerDetails.map(({ modalId, html }) => (
    <div id={modalId} hidden>
      <div class="p-6 text-foreground" set:html={html} />
    </div>
  ))}

  <!-- Modal dialog -->
  <dialog
    id="yusuke-modal"
    class="backdrop:bg-black/50 backdrop:backdrop-blur-sm rounded-lg shadow-lg bg-background border border-border p-2 w-[95%] md:w-2/3 m-auto"
  >
    <div class="flex flex-col h-full max-h-[90vh]">
      <div class="flex items-center justify-between p-6 border-b border-border">
        <h2 id="yusuke-modal-title" class="text-2xl font-light text-foreground"></h2>
        <button
          id="yusuke-modal-close"
          type="button"
          class="text-text-secondary hover:text-foreground transition-colors focus-visible:outline-2 focus-visible:outline-offset-2"
          aria-label="閉じる"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>
      <div id="yusuke-modal-body" class="flex-1 overflow-y-auto h-max"></div>
    </div>
  </dialog>

  <script>
    function init() {
      const modal = document.getElementById("yusuke-modal") as HTMLDialogElement
      if (!modal) return
      const modalTitle = document.getElementById("yusuke-modal-title")!
      const modalBody = document.getElementById("yusuke-modal-body")!

      function closeModal() {
        modal.style.opacity = "0"
        modal.style.transform = "scale(0.95)"
        setTimeout(() => {
          modal.close()
          setTimeout(() => {
            modal.style.opacity = ""
            modal.style.transform = ""
          }, 50)
        }, 200)
      }

      document.addEventListener("click", (e) => {
        const btn = (e.target as Element).closest<HTMLElement>("[data-modal-id]")
        if (!btn) return
        const id = btn.dataset.modalId!
        const title = btn.dataset.modalTitle!
        const content = document.getElementById(id)
        if (!content) return
        modalTitle.textContent = title
        modalBody.innerHTML = content.innerHTML
        modal.showModal()
      })

      document.getElementById("yusuke-modal-close")!.addEventListener("click", closeModal)

      modal.addEventListener("click", (e) => {
        if (e.target === modal) closeModal()
      })
    }

    document.addEventListener("astro:page-load", init)
  </script>
</BaseLayout>
