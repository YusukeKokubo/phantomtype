---
export const prerender = true

import type { City, Photo } from "../../@types/Photo"
import picsData from "../../public/pics.json"
import CityNav from "../components/CityNav.astro"
import Header from "../components/Header.astro"
import PhotoCard from "../components/PhotoCard.astro"
import BaseLayout from "../layouts/BaseLayout.astro"

export function getStaticPaths() {
  const cities = picsData as City[]
  return cities
    .filter((c) => c.city !== "yusuke")
    .map((cityData) => ({
      params: { city: cityData.city },
      props: { cityData, cities },
    }))
}

interface Props {
  cityData: City
  cities: City[]
}

const { cityData, cities } = Astro.props
const { city } = Astro.params

const publicHost = import.meta.env.PUBLIC_HOST || ""
const examplePic = cityData.locations[0]?.pics[0]
const ogImage = examplePic
  ? `${publicHost}${encodeURI(examplePic.url)}`
  : undefined
const ogUrl = `${publicHost}/${city}`

function byDatetime(a: Photo, b: Photo): number {
  return b.exif!.DateTimeOriginal < a.exif!.DateTimeOriginal ? 1 : -1
}

const allPics = cityData.locations
  .flatMap((loc) => loc.pics)
  .filter((p) => p.exif)
  .sort(byDatetime)
---

<BaseLayout
  title={`${city.toUpperCase()} | PHANTOM TYPE`}
  description={`${city} の写真ギャラリー`}
  ogImage={ogImage}
  ogUrl={ogUrl}
>
  <a href="#main-content" class="skip-link">メインコンテンツへスキップ</a>
  <div class="flex flex-col gap-8 mb-8">
    <Header city={city} cities={cities} />
    <main id="main-content" class="px-1 py-4">
      <h1 class="text-4xl text-center uppercase mb-6">{city}</h1>
      <div class="columns-1 md:columns-2 lg:columns-3 gap-3" role="list">
        {allPics.map((p, index) => (
          <PhotoCard photo={p} city={city} priority={index === 0} />
        ))}
      </div>
    </main>
    <CityNav city={city} cities={cities} />
  </div>
</BaseLayout>
